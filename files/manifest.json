{
  "manifest_version": 3,
  "name": "飲食店リスト取得ツール",
  "version": "2.0.0",
  "description": "食べログ・ホットペッパーの検索結果から店舗情報を自動取得してCSVダウンロード",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://tabelog.com/*",
    "https://www.hotpepper.jp/*",
    "https://hotpepper.jp/*",
    "https://www.google.com/maps/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://tabelog.com/*",
        "https://www.hotpepper.jp/*",
        "https://hotpepper.jp/*",
        "https://www.google.com/maps/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
